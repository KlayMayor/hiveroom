    "verify:testnet": "hardhat verify --network abstractTestnet",
    "verify:mainnet": "hardhat verify --network abstractMainnet"
  },
  "devDependencies": {
    "@matterlabs/hardhat-zksync": "^1.3.0",
    "@matterlabs/hardhat-zksync-deploy": "^1.5.0",
    "@matterlabs/hardhat-zksync-solc": "^1.3.0",
    "@matterlabs/hardhat-zksync-upgradable": "^1.5.0",
    "@matterlabs/hardhat-zksync-verify": "^1.6.0",
    "@matterlabs/zksync-contracts": "^0.6.1",
    "@openzeppelin/contracts": "^5.0.2",
    "@openzeppelin/contracts-upgradeable": "^5.0.2",
    "@openzeppelin/hardhat-upgrades": "^3.2.1",
    "@types/node": "^20.12.12",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.4",
    "solc": "^0.8.24",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
