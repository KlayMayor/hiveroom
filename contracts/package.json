{
  "name": "hiveroom-contracts",
  "version": "1.0.0",
  "description": "HiveRoom smart contracts for Abstract chain",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat deploy-zksync --network abstractTestnet",
